# Canonical: A.R.I.S.E/.env — then run: npm run sync-env (copies to mobile/.env).
# Always restart Metro after changes: npm run start:clean
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenRouter key (sk-or-v1-...) or Google Gemini API key (AIza...)
EXPO_PUBLIC_GEMINI_API_KEY=your_openrouter_or_gemini_key
EXPO_PUBLIC_GEMINI_MODEL=google/gemini-2.0-flash-001

# Optional: OpenRouter app attribution (recommended for production)
EXPO_PUBLIC_APP_URL=https://your-app-domain.com
EXPO_PUBLIC_APP_NAME=ARISE

# Optional: Google Cloud Vision OCR (separate from Gemini/OpenRouter)
EXPO_PUBLIC_VISION_API_KEY=your_google_vision_api_key
